# Backend
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost

# Postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=coaching
POSTGRES_PASSWORD=change-me
POSTGRES_DB=coaching

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Auth (JWT)
JWT_ACCESS_SECRET=change-me-access
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=change-me-refresh
JWT_REFRESH_TTL=7d
BCRYPT_SALT_ROUNDS=12

# Bootstrap: creates the first Coach account on first boot if none exists yet
SEED_COACH_EMAIL=coach@example.com
SEED_COACH_PASSWORD=change-me-please
